---
import { site, type SiteNavItem } from "../content/site";
import Button from "./Button.astro";
import { allUrls } from "../assets/allUrls.js";

const { brand = site.name, nav = site.nav } = Astro.props as {
  brand?: string;
  nav?: SiteNavItem[];
};

const path = Astro.url.pathname;
const isActive = (href: string) => (href === "/" ? path === "/" : path.startsWith(href));

const callForSpeakersLink = allUrls.callForSpeakersLink;
---

<header class="header">
  <div class="header__inner">
    <a class="header__brand" href="/">
      <img src="/logo.svg" alt="CAKE conf logo" width="140" height="140" />
    </a>
    <a href={callForSpeakersLink} target="_blank" rel="noopener noreferrer">
      <Button class="success-btn">Call for speakers</Button>
    </a>
    </div>
</header>
