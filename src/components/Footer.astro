---
import { site, type SiteConfig } from "../content/site";
import { allUrls } from "../assets/allUrls.js";

type Author = SiteConfig["author"];

const { author = site.author } = Astro.props as { author?: Author };
const year = new Date().getFullYear();
const getUpdatesLink = allUrls.getUpdatesLink;
const contentBytesLink = allUrls.contentBytes;
---

<footer class="footer">
  <div class="footer__inner">
    <p class="footer__meta">
      © {year}
      {author.url ? <a href={contentBytesLink}>{author.name}</a> : author.name}
    </p>

    <div class="footer__links">
      {
        author.email && (
          <a class="footer__link" href={`mailto:${author.email}`}>
            Email
          </a>
        )
      }
      {
        author.socials?.instagram && (
          <a
            class="footer__link"
            href={author.socials.instagram}
            target="_blank"
            rel="noopener"
          >
            Instagram
          </a>
        )
      }
      {
        author.socials?.linkedin && (
          <a
            class="footer__link"
            href={author.socials.linkedin}
            target="_blank"
            rel="noopener"
          >
            LinkedIn
          </a>
        )
      }
      <a class="footer__link" href={getUpdatesLink} target="_blank" rel="noopener">Get updates</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
  }

  .footer__inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 50px;
    font-size: 13px;
  }

  .footer__meta {
    margin: 0;
    color: var(--muted);
  }
  .footer__links {
    display: flex;
    gap: var(--space-3);
  }
  .footer__link {
    color: var(--muted);
    text-decoration: none;
  }
  .footer__link:hover {
    color: var(--link);
  }

  @media only screen and (max-width: 768px) {
    .footer__inner {
      flex-direction: column;
    }
  }
</style>
