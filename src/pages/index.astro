---
import Base from "../layouts/Base.astro";
import Section from "../components/Section.astro";
import { site } from "../content/site";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: site.name,
  url: site.url,
  inLanguage: site.locale
};

import Speakers from "../components/LandingPage/Speakers.astro";
import Quotes from "../components/LandingPage/Quotes.astro";
import Audience from "../components/LandingPage/Audience.astro";
import Description from "../components/LandingPage/Description.astro";
import Partners from "../components/LandingPage/Partners.astro";
---

<Base
  title={site.name}
  description={site.description}
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <Section>
    <article class="prose intro-text">
      <h1>The event uniting <span class="green-text">content</span> enthusiasts is <span class="pink-text">back</span>.</h1>

        <p>24–25 September 2026<br />
        Kraków, Poland</p>
    </article>
  </Section>
  <Speakers />
  <Quotes />
  <Audience />
  <Description />
  <Partners />
</Base>
